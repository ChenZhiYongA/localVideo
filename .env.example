FRONTEND_ORIGIN=http://localhost:5173
DATA_DIR=
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# Windows 便携包示例（可执行文件一般在 bin 下）：
# FFMPEG_PATH=D:\env\ffmpeg-master-latest-win64-gpl-shared\bin\ffmpeg.exe
# FFPROBE_PATH=D:\env\ffmpeg-master-latest-win64-gpl-shared\bin\ffprobe.exe
TRANSCODE_CONCURRENCY=2
HLS_SEGMENT_DURATION=6

# Telegram Bot（可选，也可在网页设置中配置）
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=
# TELEGRAM_SAVE_DIRECTORY=
# TELEGRAM_ALLOWED_USER_IDS=
# TELEGRAM_LOCAL_API_URL=http://127.0.0.1:8081
