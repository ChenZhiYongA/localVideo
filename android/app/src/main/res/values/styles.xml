<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.LocalTube.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.LocalTube.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.LocalTube.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.LocalTube.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Widget.LocalTube.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/lt_red</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.LocalTube.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.LocalTube.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/lt_red</item>
        <item name="hintTextColor">@color/lt_red</item>
    </style>

    <style name="Widget.LocalTube.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/bg_surface_2</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipCornerRadius">8dp</item>
    </style>

    <style name="SectionHeader">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingTop">@dimen/spacing_xl</item>
        <item name="android:paddingBottom">@dimen/spacing_sm</item>
    </style>
</resources>
