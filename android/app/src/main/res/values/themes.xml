<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LocalTube" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/lt_red</item>
        <item name="colorPrimaryVariant">@color/lt_red_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/bg_surface_3</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="bottomNavigationStyle">@style/Widget.LocalTube.BottomNavigation</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
    </style>

    <style name="Theme.LocalTube.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_primary</item>
        <item name="postSplashScreenTheme">@style/Theme.LocalTube</item>
    </style>

    <style name="ShapeSmall" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>
    <style name="ShapeMedium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeLarge" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Widget.LocalTube.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="elevation">0dp</item>
        <item name="android:background">@color/bg_surface</item>
    </style>
</resources>
